{
  "name": "crash-game",
  "private": true,
  "workspaces": [
    "services/*",
    "packages/*",
    "frontend/*"
  ],
  "scripts": {
    "docker:up": "docker compose up",
    "docker:down": "docker compose down",
    "docker:prune": "docker compose down -v --rmi all --remove-orphans && docker volume prune -f",
    "test": "bun test packages/messaging/tests/unit services/games/tests/unit services/wallets/tests/unit",
    "test:e2e": "bun test services/games/tests/e2e services/wallets/tests/e2e"
  },
  "devDependencies": {
    "bun-types": "latest"
  }
}
